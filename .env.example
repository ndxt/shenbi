AI_PROVIDER=openai-compatible
AI_PROVIDERS=openai-compatible,nextai,centit,uniapi,kimi,deepseek,minimax
AI_OPENAI_COMPAT_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
AI_OPENAI_COMPAT_API_KEY=your_api_key_here
AI_PLANNER_MODEL=GLM-4.7
AI_BLOCK_MODEL=GLM-4.6
AI_AVAILABLE_MODELS=GLM-4.6,GLM-4.7,GLM-5
AI_NON_THINKING_MODELS=

# Available models:
# - GLM-4.6
# - GLM-4.7
# - GLM-5

# Generic provider-specific aliases for any OpenAI-compatible vendor:
# NEXTAI_BASE_URL=https://api.nextaicore.com/v1
# NEXTAI_API_KEY=your_nextai_key_here
# NEXTAI_PLANNER_MODEL=gemini-2.5-pro
# NEXTAI_BLOCK_MODEL=gemini-2.5-pro
# NEXTAI_MODELS=gemini-2.5-pro
# NEXTAI_NON_THINKING_MODELS=gpt-4o-mini
# CENTIT_BASE_URL=https://cloud.centit.com/locode/api/llvm
# CENTIT_API_KEY=your_centit_key_here
# CENTIT_PLANNER_MODEL=qwq
# CENTIT_BLOCK_MODEL=qwq
# CENTIT_MODELS=qwq
# CENTIT_NON_THINKING_MODELS=
# UNIAPI_BASE_URL=https://hk.uniapi.io/v1
# UNIAPI_API_KEY=your_uniapi_key_here
# UNIAPI_PLANNER_MODEL=gemini-2.5-pro
# UNIAPI_BLOCK_MODEL=gemini-2.5-pro
# UNIAPI_MODELS=gemini-2.5-flash,gemini-2.5-pro,gemini-3-flash-preview,gemini-3-pro-preview
# UNIAPI_NON_THINKING_MODELS=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_API_KEY=your_kimi_key_here
# KIMI_PLANNER_MODEL=kimi-k2.5
# KIMI_BLOCK_MODEL=kimi-k2.5
# KIMI_MODELS=kimi-k2.5,kimi-k2
# KIMI_NON_THINKING_MODELS=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=your_deepseek_key_here
# DEEPSEEK_PLANNER_MODEL=deepseek-chat
# DEEPSEEK_BLOCK_MODEL=deepseek-chat
# DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner
# DEEPSEEK_NON_THINKING_MODELS=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_API_KEY=your_minimax_key_here
# MINIMAX_PLANNER_MODEL=MiniMax-M2.5
# MINIMAX_BLOCK_MODEL=MiniMax-M2.5
# MINIMAX_MODELS=MiniMax-M2,MiniMax-M2.5
# MINIMAX_NON_THINKING_MODELS=

# Legacy aliases still supported by the backend loader:
# - VITE_OPENAI_BASE_URL
# - VITE_OPENAI_API_KEY
# - VITE_OPENAI_PLANNER_MODEL
# - VITE_OPENAI_BLOCK_MODEL
