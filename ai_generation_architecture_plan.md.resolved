## 六、数据结构定义

### 6.1 新增类型

```typescript
// ========== Page Classification ==========
interface PageClassification {
  pageType: PageType;
  intent: string;           // "创建一个员工考勤管理仪表盘"
  entities: string[];       // ["员工", "考勤", "出勤率"]
  suggestedSkeleton: string; // skeleton template id
}

// ========== Page Skeleton ==========
interface ZoneSpec {
  id: string;
  type: ZoneType;
  description: string;
  optional?: boolean;
  suggestedGroup?: ComponentGroup;
}

interface PageSkeleton {
  pageType: PageType;
  layout: {
    component: string;
    props: Record<string, unknown>;
  };
  zones: ZoneSpec[];
}

// ========== Enriched Block ==========
interface EnrichedBlock {
  zoneId: string;
  zoneType: ZoneType;
  description: string;
  componentGroup: ComponentGroup;
  primaryComponent: string;         // e.g. 'Table', 'Form'
  supportComponents: string[];      // e.g. ['FormItem', 'Input', 'Select']
  contractBrief: string;            // Level 2 摘要文本，用于注入 prompt
  goldenExample?: string;           // JSON string of example SchemaNode
}

// ========== Contract Summaries ==========
interface ContractSummaryStore {
  level0: ComponentIndex;
  level1: ComponentGroupSummary[];
  level2: Map<string, ComponentBrief>;
  goldenExamples: Map<ZoneType, string>;  // zone type -> example SchemaNode JSON
}
```

### 6.2 改造 PagePlan（向后兼容）

```typescript
interface PagePlan {
  pageTitle: string;
  pageType: PageType;              // 新增
  skeleton: string;                 // 引用哪个骨架模板
  blocks: Array<{
    id: string;
    type: string;                   // 放开：不再限制为组件名，允许 zone type
    description: string;
    components: string[];           // 放开：允许所有 contract 组件
    componentGroup: ComponentGroup; // 新增
    priority: number;
    complexity: 'simple' | 'medium' | 'complex';
  }>;
}
```

