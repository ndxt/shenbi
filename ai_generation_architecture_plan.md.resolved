#### 1.5 改造 assembleSchema 加入布局包裹

```typescript
async function assembleSchema(input: AssembleSchemaInput): Promise<PageSchema> {
  return {
    id: 'ai-generated-page',
    name: input.plan.pageTitle,
    body: [
      {
        component: 'Space',
        id: 'page-root',
        props: { direction: 'vertical', size: 24, style: { width: '100%', padding: '24px' } },
        children: input.blocks.map((block) => block.node),
      },
    ],
  };
}
```

#### 1.6 放开 validateNode

改为**基于 contracts 校验**而非硬编码白名单：

```typescript
import { builtinContractMap } from '@shenbi/schema';

function validateNode(node: SchemaNode): SchemaNode {
  // 只校验是否存在于 contract 注册表中
  if (!builtinContractMap[node.component]) {
    // 降级为 Container，而不是报错
    node.component = 'Container';
  }
  if (Array.isArray(node.children)) {
    for (const child of node.children) {
      if (isNodeLike(child)) {
        validateNode(child);
      }
    }
  }
  return node;
}
```

#### 1.7 Block Generator 并行化

```typescript
// 当前是串行：
for (const block of plan.blocks) {
  const generated = await generateBlock.execute({ block, request, context });
}

// 改为并行：
const blockPromises = plan.blocks.map(async (block) => {
  yield { type: 'tool:start', data: { tool: 'generateBlock', label: `Generating ${block.type}` } };
  const generated = await generateBlock.execute({ block, request, context });
  return { block, generated };
});
const results = await Promise.all(blockPromises);
```

> [!WARNING]
> 并行化需要处理 SSE event 的乱序问题。要么接受乱序，要么用 event buffer 排序后发出。
> Phase 1 推荐先保持串行，Phase 2 再做并行优化。

