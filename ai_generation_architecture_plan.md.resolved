### Phase 2: 组件族 + 模板 + Contracts 摘要（~2 周）

**目标**: 建立 Contract 摘要编译体系 + 页面骨架模板 + 组件族索引。

#### 2.1 Contract 摘要编译器

**新建文件**: `packages/ai-agents/src/contracts/`

```
packages/ai-agents/src/contracts/
  compiler.ts        — 从 builtinContracts 自动编译 3 层摘要
  component-groups.ts — 组件族定义和映射
  page-skeletons.ts  — 页面骨架模板
  golden-examples/   — 按 zone type 的示例 SchemaNode
    kpi-row.json
    data-table.json
    filter.json
    form-body.json
    detail-info.json
    page-header.json
```

核心编译逻辑：

```typescript
// compiler.ts
import { builtinContracts } from '@shenbi/schema';

export function compileLevel0(): ComponentIndex {
  const index: ComponentIndex = {
    layout: [], general: [], navigation: [],
    dataEntry: [], dataDisplay: [], feedback: [],
  };
  for (const c of builtinContracts) {
    const category = c.category ?? 'other';
    const bucket = categoryToBucket(category);
    index[bucket].push(c.componentType);
  }
  return index;
}

export function compileLevel2(componentType: string): ComponentBrief | undefined {
  const contract = builtinContracts.find(c => c.componentType === componentType);
  if (!contract) return undefined;

  const props: Record<string, any> = {};
  for (const [key, prop] of Object.entries(contract.props ?? {})) {
    if (prop.deprecated) continue;  // 过滤废弃 props
    props[key] = {
      type: prop.type,
      ...(prop.required ? { required: true } : {}),
      ...(prop.default !== undefined ? { default: prop.default } : {}),
      ...(prop.enum ? { enum: prop.enum } : {}),
      ...(prop.description ? { description: prop.description } : {}),
    };
  }

  return {
    componentType: contract.componentType,
    category: contract.category ?? 'other',
    props,
    children: contract.children ?? { type: 'none' },
  };
}

// 编译成 prompt-ready 文本
export function compileLevel2Text(components: string[]): string {
  return components
    .map(name => {
      const brief = compileLevel2(name);
      if (!brief) return '';
      return `### ${name}
Props: ${JSON.stringify(brief.props, null, 0)}
Children: ${brief.children.type}${brief.children.description ? ` (${brief.children.description})` : ''}`;
    })
    .filter(Boolean)
    .join('\n\n');
}
```

#### 2.2 引入 Page Classifier（L1）

**改动**: [pageBuilderOrchestrator](file:///d:/Code/lowcode/shenbi-codes/shenbi/packages/ai-agents/src/orchestrators/page-builder-orchestrator.ts#33-92) 新增第一步

```typescript
export async function* pageBuilderOrchestrator(...) {
  // L1: 分类
  const classifier = getRequiredTool('classifyPage');
  const classification = await classifier.execute({ request, context });

  // L2: 骨架规划
  const planner = getRequiredTool('planPage');
  const plan = await planner.execute({ request, context, classification });

  // L3: 模板选择 (可选，Phase 2 可以在 planner 里完成)
  // ...

  // L4: Block 生成
  for (const block of plan.blocks) {
    const enriched = enrichBlock(block, contractStore);
    const generated = await generateBlock.execute({ enrichedBlock: enriched, request });
  }

  // L5: 组装
  const schema = await assembleSchema.execute({ plan, blocks, request });
}
```

