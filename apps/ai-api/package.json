{
  "name": "@shenbi/ai-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:mastra": "node ../../scripts/dev-mastra-ai-api.mjs",
    "build": "tsc -p tsconfig.json --noEmit && node scripts/build.mjs",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs run --passWithNoTests",
    "test:mastra-phase1": "tsc -p tsconfig.json --noEmit && node ./node_modules/vitest/vitest.mjs run src/runtime/agent-runtime.test.ts src/runtime/modify-schema.test.ts src/runtime/normalize-schema.test.ts src/runtime/component-catalog.test.ts src/runtime/runtime-switch.test.ts src/test/app-mastra-smoke.test.ts",
    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@shenbi/ai-agents": "workspace:*",
    "@shenbi/ai-contracts": "workspace:*",
    "@shenbi/mastra-runtime": "workspace:*",
    "@shenbi/schema": "workspace:*",
    "hono": "^4.7.4",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
