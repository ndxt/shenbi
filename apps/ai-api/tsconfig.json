{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "jsx": "react-jsx",
    "baseUrl": "../..",
    "paths": {
      "@shenbi/ai-agents": ["packages/ai-agents/src/index.ts"],
      "@shenbi/ai-contracts": ["packages/ai-contracts/src/index.ts"],
      "@shenbi/schema": ["packages/schema/types/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
