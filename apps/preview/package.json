{
  "name": "@shenbi/preview",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:html": "playwright test --reporter=list,html",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:crud": "playwright test e2e/crud.spec.ts",
    "test:e2e:report": "node scripts/show-playwright-report.cjs",
    "test:e2e:install": "playwright install"
  },
  "dependencies": {
    "@shenbi/editor-core": "workspace:*",
    "@shenbi/editor-plugin-ai-chat": "workspace:*",
    "@shenbi/editor-plugin-files": "workspace:*",
    "@shenbi/editor-ui": "workspace:*",
    "@shenbi/engine": "workspace:*",
    "@shenbi/schema": "workspace:*",
    "antd": "^6.3.0",
    "lucide-react": "^0.575.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
