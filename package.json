{
  "name": "shenbi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm -r run build",
    "type-check": "pnpm -r run type-check",
    "test": "pnpm -r run test",
    "perf": "pnpm --filter @shenbi/engine perf",
    "test:gate": "pnpm test && pnpm perf",
    "test:phase1.5": "pnpm --filter @shenbi/engine test && pnpm --filter @shenbi/preview test && pnpm --filter @shenbi/preview test:e2e",
    "test:phase1.5:gate": "pnpm test:phase1.5 && pnpm perf",
    "test:engine": "pnpm --filter @shenbi/engine test",
    "dev:preview": "pnpm --filter @shenbi/preview dev",
    "test:e2e:preview": "pnpm --filter @shenbi/preview test:e2e",
    "test:e2e:preview:html": "pnpm --filter @shenbi/preview test:e2e:html",
    "test:e2e:preview:headed": "pnpm --filter @shenbi/preview test:e2e:headed",
    "test:e2e:preview:crud": "pnpm --filter @shenbi/preview test:e2e:crud",
    "test:e2e:preview:report": "pnpm --filter @shenbi/preview test:e2e:report",
    "test:e2e:preview:install": "pnpm --filter @shenbi/preview test:e2e:install"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  }
}
