    "districtData": {
      "default": [
        { "district": "浦东新区", "value": 28 },
        { "district": "黄浦区",   "value": 12 },
        { "district": "徐汇区",   "value": 11 },
        { "district": "静安区",   "value": 10 },
        { "district": "长宁区",   "value": 9  },
        { "district": "虹桥枢纽", "value": 8  },
        { "district": "闵行区",   "value": 13 },
        { "district": "其他",     "value": 9  }
