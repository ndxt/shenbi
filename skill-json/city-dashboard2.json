  "body": {
    "id": "page-root",
    "component": "Container",
    "style": {
      "minHeight": "100vh",
      "background": "#0F172A",
      "padding": "16px",
      "fontFamily": "'Fira Code', 'Fira Sans', monospace"
    },
    "children": [
      {
        "id": "page-header",
        "component": "Flex",
        "props": { "justify": "space-between", "align": "center" },
        "style": { "marginBottom": "16px", "padding": "12px 16px", "background": "#1E293B", "borderRadius": "12px", "border": "1px solid #334155" },
        "children": [
          {
            "id": "header-left",
            "component": "Space",
            "props": { "size": 12 },
            "children": [
              {
                "id": "header-dot",
                "component": "Container",
                "style": { "width": "10px", "height": "10px", "borderRadius": "50%", "background": "#22C55E", "boxShadow": "0 0 8px #22C55E", "display": "inline-block" }
              },
              {
                "id": "header-title",
                "component": "Container",
                "style": { "fontSize": "20px", "fontWeight": "700", "color": "#F8FAFC", "letterSpacing": "2px" },
                "children": "智慧城市数据大屏"
              },
              {
                "id": "header-badge",
                "component": "Tag",
                "props": { "color": "green" },
                "children": "实时监控"
              }
            ]
          },
          {
            "id": "header-right",
            "component": "Space",
            "props": { "size": 16 },
            "children": [
              {
                "id": "header-time",
                "component": "Container",
                "style": { "color": "#94A3B8", "fontSize": "13px", "fontFamily": "'Fira Code', monospace" },
                "children": "2026-03-16  14:35:22"
              }
            ]
          }
        ]
      },
      {
        "id": "main-row",
        "component": "Row",
        "props": { "gutter": [16, 16] },
        "children": [
          {
            "id": "left-col",
            "component": "Col",
            "props": { "span": 6 },
            "children": [
              {
                "id": "alarm-card",
                "component": "Card",
                "props": { "title": "实时告警", "size": "small", "bordered": false },
                "style": { "background": "#1E293B", "borderRadius": "12px", "border": "1px solid #334155", "marginBottom": "16px" },
                "children": [
                  {
                    "id": "alarm-timeline",
                    "component": "Timeline",
                    "props": { "items": "{{state.alarms}}" },
                    "style": { "marginTop": "8px" }
                  }
                ]
              },
              {
                "id": "device-card",
                "component": "Card",
                "props": { "title": "设备在线率", "size": "small", "bordered": false },
                "style": { "background": "#1E293B", "borderRadius": "12px", "border": "1px solid #334155" },
                "children": [
                  {
                    "id": "device-statistic",
                    "component": "Statistic",
                    "props": {
                      "title": "在线设备 / 总设备",
                      "value": "{{state.deviceOnline}}",
                      "suffix": "{{' / ' + state.deviceTotal + ' 台'}}",
                      "valueStyle": { "color": "#22C55E", "fontSize": "22px" }
                    },
                    "style": { "marginBottom": "12px" }
                  },
                  {
                    "id": "device-progress",
                    "component": "Progress",
                    "props": {
                      "percent": "{{state.deviceOnlineRate}}",
                      "strokeColor": "#22C55E",
                      "trailColor": "#334155",
                      "format": { "type": "JSFunction", "params": ["p"], "body": "return p + '%';" }
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "center-col",
            "component": "Col",
            "props": { "span": 12 },
            "children": [
              {
                "id": "kpi-row",
                "component": "Row",
                "props": { "gutter": [12, 12] },
                "style": { "marginBottom": "16px" },
                "children": [
                  {
                    "id": "kpi-col-loop",
                    "component": "Col",
                    "props": { "span": 12 },
                    "loop": { "data": "{{state.kpis}}", "key": "{{item.id}}" },
                    "children": [
                      {
                        "id": "kpi-card",
                        "component": "Card",
                        "props": { "size": "small", "bordered": false },
                        "style": { "background": "#1E293B", "borderRadius": "10px", "border": "1px solid #334155" },
                        "children": [
                          {
                            "id": "kpi-statistic",
                            "component": "Statistic",
                            "props": {
                              "title": "{{item.title}}",
                              "value": "{{item.value}}",
                              "suffix": "{{item.suffix}}",
                              "valueStyle": { "color": "{{item.color}}", "fontSize": "24px", "fontFamily": "'Fira Code', monospace" }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "id": "trend-card",
                "component": "Card",
                "props": { "title": "近 24 小时城市运行趋势", "size": "small", "bordered": false },
                "style": { "background": "#1E293B", "borderRadius": "12px", "border": "1px solid #334155" },
                "children": [
                  {
                    "id": "trend-chart",
                    "component": "Chart.Line",
                    "props": {
                      "data": "{{state.trendData}}",
                      "xField": "hour",
                      "yField": "value",
                      "colorField": "series",
                      "theme": "classicDark",
                      "height": 260,
                      "smooth": true,
                      "legend": { "position": "top-right" },
                      "axis": {
                        "x": { "label": { "style": { "fill": "#94A3B8", "fontSize": 11 } } },
                        "y": { "label": { "style": { "fill": "#94A3B8", "fontSize": 11 } } }
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "right-col",
            "component": "Col",
            "props": { "span": 6 },
            "children": [
              {
                "id": "region-card",
                "component": "Card",
                "props": { "title": "区域事件分布", "size": "small", "bordered": false },
                "style": { "background": "#1E293B", "borderRadius": "12px", "border": "1px solid #334155", "marginBottom": "16px" },
                "children": [
                  {
                    "id": "region-pie",
                    "component": "Chart.Pie",
                    "props": {
                      "data": "{{state.regionData}}",
                      "angleField": "value",
                      "colorField": "region",
                      "innerRadius": 0.5,
                      "theme": "classicDark",
                      "height": 220,
                      "legend": { "position": "bottom" },
                      "label": { "text": "region", "style": { "fill": "#F8FAFC", "fontSize": 11 } }
                    }
                  }
                ]
              },
              {
                "id": "events-card",
                "component": "Card",
                "props": { "title": "热门事件 Top 5", "size": "small", "bordered": false },
                "style": { "background": "#1E293B", "borderRadius": "12px", "border": "1px solid #334155" },
                "children": [
                  {
                    "id": "events-table",
                    "component": "Table",
                    "props": {
                      "dataSource": "{{state.topEvents}}",
                      "rowKey": "rank",
                      "pagination": false,
                      "size": "small"
                    },
                    "columns": [
                      { "title": "#", "dataIndex": "rank", "width": 36,
                        "render": { "component": "Tag", "props": { "color": "{{text === 1 ? 'gold' : text === 2 ? 'silver' : 'default'}}" }, "children": "{{text}}" }
                      },
                      { "title": "事件类型", "dataIndex": "event" },
                      { "title": "次数", "dataIndex": "count", "width": 56,
                        "render": { "component": "Container", "style": { "color": "#F97316", "fontFamily": "'Fira Code', monospace", "fontWeight": "600" }, "children": "{{text}}" }
                      },
                      { "title": "趋势", "dataIndex": "trend", "width": 44,
                        "render": { "component": "Container", "style": { "color": "{{text === '↑' ? '#F97316' : text === '↓' ? '#22C55E' : '#94A3B8'}}", "fontSize": "16px", "textAlign": "center" }, "children": "{{text}}" }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
