{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shenbi/schema": ["packages/schema/types/index.ts"],
      "@shenbi/engine": ["packages/engine/src/index.ts"],
      "@shenbi/editor-core": ["packages/editor-core/src/index.ts"],
      "@shenbi/editor-ui": ["packages/editor-ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "coverage"]
}
